# =============================
# RoadKeeper Backend - .env.example
# =============================

# Database
# Example (Neon/Postgres):
# DATABASE_URL=postgresql+psycopg2://user:password@host/dbname?sslmode=require
DATABASE_URL=

# Security
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Frontend base URL (used in password reset links)
FRONTEND_URL=http://localhost:5173

# =============================
# SMTP Email settings
# =============================
# These are required if you want real emails for forgot-password.
# If omitted, the backend logs reset links in console (dev fallback).

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
NOTIFICATIONS_CRON_SECRET=

# ---------- Example: Gmail (App Password required) ----------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu_correo@gmail.com
# SMTP_PASSWORD=tu_app_password_de_16_caracteres
# SMTP_FROM=RoadKeeper <tu_correo@gmail.com>

# ---------- Example: Mailtrap ----------
# SMTP_HOST=sandbox.smtp.mailtrap.io
# SMTP_PORT=587
# SMTP_USER=tu_mailtrap_user
# SMTP_PASSWORD=tu_mailtrap_password
# SMTP_FROM=RoadKeeper <noreply@roadkeeper.local>

